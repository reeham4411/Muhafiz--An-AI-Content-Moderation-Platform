# Server
PORT=5001
NODE_ENV=development

# MongoDB - use the Docker service name "mongo", not localhost, when running via docker-compose
MONGO_URI=mongodb://mongo:27017/content_moderation

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# AI Moderation Provider
# Leave GEMINI_API_KEY empty/unset to automatically fall back to the deterministic MockModerationProvider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Uploads
MAX_UPLOAD_MB=8
UPLOAD_DIR=uploads

# Optional: seed an admin user automatically (see README "create admin user" section)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=admin123
